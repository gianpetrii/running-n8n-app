# Copia este archivo a .env.local y completa los valores
# cp .env.local.example .env.local


# Supabase → Settings → Database → Connection string → URI → Transaction (pooler :6543)
# En WSL/local NO uses db.*.supabase.co:5432 (suele ser solo IPv6).
DATABASE_URL=

# Secreto compartido: mismo valor en Vercel "CRON_SECRET" y Authorization Bearer en GitHub Actions
CRON_SECRET=

# Listado a scrapear (default: Argentina en Corredor Promedio)
# CORREDOR_LISTING_URL=https://www.corredorpromedio.com/carreras/argentina/

# Límites (opcional)
# SCRAPE_MAX_LISTING_PAGES=3
# SCRAPE_DETAIL_CONCURRENCY=2
# SCRAPE_FETCH_DETAIL=true

# Imágenes: priorizar og:image del detalle (mejor calidad; suele ser imagen RRSS sin thumb 150px)
# IMAGE_PREFER_OG=true

# Crop lateral al publicar (quita ~10% izq/der; logo CP suele estar abajo-derecha, menos texto central)
# IMAGE_CROP_SIDES=true
# IMAGE_CROP_SIDE_PERCENT=10
# APP_URL=https://tu-app.vercel.app

# Instagram Graph API
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
