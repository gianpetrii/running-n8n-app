# =============================================================================
# Running Argentina — variables de entorno
# =============================================================================
#
# Setup:
#   cp .env.local.example .env.local
#
# Cargar en la terminal (zsh/bash):
#   set -a && source .env.local && set +a
#
# IMPORTANTE: APP_URL sin barra final (/)
#   ✅ https://tu-app.vercel.app
#   ❌ https://tu-app.vercel.app/
#   Con barra final, el curl a Vercel devuelve "Redirecting..." (308).


# --- Base de datos ---
# Supabase → Settings → Database → Connection string → URI → Transaction (pooler :6543)
# En WSL/local NO uses db.*.supabase.co:5432 (suele ser solo IPv6).
DATABASE_URL=postgresql://user:password@host.pooler.supabase.com:6543/postgres

# --- Cron / jobs ---
# Generar: openssl rand -hex 32
# Mismo valor en Vercel (CRON_SECRET) y en GitHub Actions secrets.
CRON_SECRET=

# --- Scraping (opcional; defaults en código) ---
# CORREDOR_LISTING_URL=https://www.corredorpromedio.com/carreras/argentina/
# SCRAPE_MAX_LISTING_PAGES=3
# SCRAPE_DETAIL_CONCURRENCY=2
# SCRAPE_FETCH_DETAIL=true
# IMAGE_PREFER_OG=true

# --- Imágenes para Instagram ---
# Crop lateral (~10% izq/der). Instagram descarga desde APP_URL + /api/media/event-image/{id}
# - Producción: APP_URL = tu dominio Vercel (HTTPS).
# - Local: si APP_URL es localhost, se usa la imagen original (Meta no alcanza localhost).
# - Probar crop sin publicar: abrir en el browser
#     ${APP_URL%/}/api/media/event-image/{uuid-del-evento}
IMAGE_CROP_SIDES=true
IMAGE_CROP_SIDE_PERCENT=10
APP_URL=https://running-n8n-app.vercel.app

# --- Instagram Graph API ---
# ID numérico de la cuenta Business (Graph API Explorer → instagram_business_account)
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841410908621556
# Page access token long-lived (~60 días). Renovar con los comandos al final.
INSTAGRAM_ACCESS_TOKEN=

# Máximo de publicaciones por ejecución del job (1 = de a una para pruebas)
PUBLISH_MAX_PER_RUN=1

# --- Solo para renovar token (la app no los usa en runtime) ---
META_APP_ID=
META_APP_SECRET=
# Token corto del Graph API Explorer (1–2 h)
INSTAGRAM_SHORT_LIVED_TOKEN=


# =============================================================================
# Probar jobs manualmente (después de: set -a && source .env.local && set +a)
# =============================================================================
#
# Paso 1 — Crop (sin Instagram): abrir en browser o:
#   curl -I "${APP_URL%/}/api/media/event-image/UUID-DEL-EVENTO"
#
# Paso 2 — Publish desde local (job en tu Mac, imagen crop desde Vercel si APP_URL es Vercel):
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     http://localhost:3000/api/jobs/publish-instagram
#
# Paso 3 — Publish en Vercel (igual que el cron de producción):
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     "${APP_URL%/}/api/jobs/publish-instagram"
#
# Sync de carreras:
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     http://localhost:3000/api/jobs/sync-events
#   curl -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     "${APP_URL%/}/api/jobs/publish-instagram"
#
# Respuesta esperada publish: {"ok":true,"summary":{"candidates":N,"published":1,...}}
# Si ves "Redirecting...": APP_URL tiene barra final o falta https://


# =============================================================================
# Renovar INSTAGRAM_ACCESS_TOKEN long-lived (~60 días)
# =============================================================================
#
# 1) User token corto → long-lived:
# curl -G "https://graph.facebook.com/v21.0/oauth/access_token" \
#   --data-urlencode "grant_type=fb_exchange_token" \
#   --data-urlencode "client_id=${META_APP_ID}" \
#   --data-urlencode "client_secret=${META_APP_SECRET}" \
#   --data-urlencode "fb_exchange_token=${INSTAGRAM_SHORT_LIVED_TOKEN}"
#
# 2) Page token de la página vinculada a @running.argentina:
# curl -G "https://graph.facebook.com/v21.0/me/accounts" \
#   --data-urlencode "access_token=LONG_LIVED_USER_TOKEN_DEL_PASO_1"
#
# 3) Copiar access_token de la página → INSTAGRAM_ACCESS_TOKEN
#    Actualizar en .env.local Y en Vercel → Settings → Environment Variables
#    Verificar: https://developers.facebook.com/tools/debug/accesstoken/
